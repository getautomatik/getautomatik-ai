from .base_agent import BaseAgent
from .tools import *

def create_hunter():
    tools = [
        {"name": "scrape_google_maps", "description": "Cerca aziende su Google Maps", "function": scrape_google_maps},
        {"name": "evaluate_market", "description": "Valuta potenziale mercato", "function": evaluate_market},
    ]
    return BaseAgent("Hunter", "Trova prospect e valuta mercati", tools)

def create_closer():
    tools = [
        {"name": "generate_email", "description": "Genera email vendita", "function": generate_email},
        {"name": "send_linkedin_connection", "description": "Invia connessione LinkedIn", "function": send_linkedin_connection},
    ]
    return BaseAgent("Closer", "Vende e chiude contratti", tools)

def create_delivery():
    tools = [
        {"name": "qualify_lead", "description": "Qualifica lead cliente", "function": qualify_lead},
        {"name": "generate_report", "description": "Genera report cliente", "function": generate_report},
    ]
    return BaseAgent("Delivery", "Serve clienti e qualifica lead", tools)

def create_analyst():
    tools = [
        {"name": "analyze_markets", "description": "Analizza mercati", "function": analyze_markets},
        {"name": "suggest_pricing", "description": "Suggerisce prezzi", "function": suggest_pricing},
        {"name": "predict_churn", "description": "Prevede abbandoni", "function": predict_churn},
    ]
    return BaseAgent("Analyst", "Analizza dati e ottimizza", tools)
